# Telegram Bot Token (required)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed user IDs (comma-separated, required)
ALLOWED_USERS=123456789,987654321

# Tmux session name (optional, defaults to "telegram-agent-bot")
TELEGRAM_AGENT_BOT_TMUX_SESSION_NAME=telegram-agent-bot

# Codex command to run in new windows (optional, defaults to "codex")
TELEGRAM_AGENT_BOT_CODEX_COMMAND=codex

# Optional per-topic agent profile defaults. New topics can override these
# through the Telegram picker without changing the global agent type.
# TELEGRAM_AGENT_BOT_CLAUDE_COMMAND=claude
# TELEGRAM_AGENT_BOT_CLAUDE_ENV_FILE=~/.telegram-agent-bot/claude.env
# Defaults are provider-independent and can be overridden for each runtime.
TELEGRAM_AGENT_BOT_CODEX_MODEL=gpt-5.4-mini
TELEGRAM_AGENT_BOT_CLAUDE_MODEL=deepseek-v4-flash
# Use auto to query the configured provider at startup; use a comma-separated
# list to pin the picker to a manual list.
# TELEGRAM_AGENT_BOT_CODEX_MODELS=auto
# TELEGRAM_AGENT_BOT_CLAUDE_MODELS=auto
# TELEGRAM_AGENT_BOT_MODEL_DISCOVERY=true
# TELEGRAM_AGENT_BOT_CODEX_REASONING_EFFORT=medium
# TELEGRAM_AGENT_BOT_CLAUDE_REASONING_EFFORT=high

# Automatic saved-account failover after usage_limit_exceeded.
# Defaults to false; keep disabled for single-account operation.
TELEGRAM_AGENT_BOT_ENABLE_ACCOUNT_ROTATION=false

# Codex transcript root (optional, defaults to ~/.codex)
# TELEGRAM_AGENT_BOT_CODEX_PROJECTS_PATH=~/.codex

# Default directory shown when creating a new Codex session (optional, defaults to ~/Projects)
# TELEGRAM_AGENT_BOT_DEFAULT_PROJECTS_PATH=~/Projects

# Optional named roots shown before directory browsing.
# Use mounted paths for other computers/VPSes, e.g. SSHFS/NFS mounts.
# TELEGRAM_AGENT_BOT_PROJECT_ROOTS=Local=~/Projects,Remote=/mnt/remote-projects

# Monitor polling interval in seconds (optional, defaults to 2.0)
TELEGRAM_AGENT_BOT_MONITOR_POLL_INTERVAL=2.0

# Maximum pending Telegram inputs held by the bot while Codex shows an
# interactive prompt. Regular busy-state inputs are sent to Codex directly.
TELEGRAM_AGENT_BOT_AGENT_INPUT_QUEUE_MAX_SIZE=20

# Drop bot-held inputs that waited this many seconds for Codex to become ready.
# Set to 0 to keep queued inputs until Codex accepts them or the queue is cleared.
TELEGRAM_AGENT_BOT_AGENT_INPUT_QUEUE_MAX_WAIT_SECONDS=1800

# Maximum time to wait for a newly launched Codex/Claude UI before forwarding
# the first pending Telegram message (optional, defaults to 180 seconds).
TELEGRAM_AGENT_BOT_AGENT_STARTUP_TIMEOUT_SECONDS=180

# Automatically check and fast-forward git source installs on startup.
# Set to false if you manage upgrades manually.
TELEGRAM_AGENT_BOT_AUTO_UPDATE=true

# Minimum seconds between automatic startup checks (optional, defaults to 86400)
TELEGRAM_AGENT_BOT_UPDATE_INTERVAL_SECONDS=86400

# Only apply automatic updates when no Codex pane is working or waiting for input.
TELEGRAM_AGENT_BOT_UPDATE_REQUIRE_IDLE=true

# When work is active, retry the idle check after this many seconds.
TELEGRAM_AGENT_BOT_UPDATE_BUSY_RETRY_SECONDS=300

# Check Codex CLI npm package updates during the same idle update loop.
TELEGRAM_AGENT_BOT_CODEX_UPDATE_CHECK=true

# Command used for npm-based Codex checks/updates.
# Use `sudo -n npm` only when the service user is allowed to run it non-interactively.
TELEGRAM_AGENT_BOT_CODEX_UPDATE_NPM=npm

# Automatically run `npm install -g @openai/codex@latest` when an idle Codex update exists.
# Set to false if you want Telegram confirmation before applying Codex CLI updates.
TELEGRAM_AGENT_BOT_CODEX_AUTO_UPDATE=true

# Show Codex commentary/thinking updates in Telegram (optional)
TELEGRAM_AGENT_BOT_SHOW_COMMENTARY_MESSAGES=true

# Re-send long-running Thinking status at this interval so Telegram topics stay active.
TELEGRAM_AGENT_BOT_STATUS_REPOST_INTERVAL=60.0

# ── Voice transcription ──────────────────────────────────────────────────
# Comma-separated provider IDs tried in order (openai, google).
# On failure the next provider is attempted automatically.
AI_TRANSCRIPTION_PROVIDERS=openai

# OpenAI-compatible provider (OpenAI, Groq, Azure, etc.)
# AI_TRANSCRIPTION_OPENAI_API_KEY=
# AI_TRANSCRIPTION_OPENAI_BASE_URL=https://api.openai.com/v1
# AI_TRANSCRIPTION_OPENAI_MODEL=gpt-4o-transcribe

# Google Gemini provider
# AI_TRANSCRIPTION_GOOGLE_API_KEY=
# AI_TRANSCRIPTION_GOOGLE_MODEL=gemini-2.0-flash-lite

# ── Agent type selection ─────────────────────────────────────────────────
# Controls which CLI is launched, where transcripts are stored, and which
# update mechanism is used.
#
#   codex  → codex CLI + ~/.codex transcripts + @openai/codex npm package
#   claude → claude CLI + ~/.claude/projects transcripts + @anthropic/claude-code npm
#
TELEGRAM_AGENT_BOT_AGENT_TYPE=codex

# Optional Anthropic API key (needed for Claude Code; scrubbed from child processes)
# ANTHROPIC_API_KEY=
