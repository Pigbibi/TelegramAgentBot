# Telegram Bot Token (required)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed user IDs (comma-separated, required)
ALLOWED_USERS=123456789,987654321

# Tmux session name (optional, defaults to "ccbot")
TMUX_SESSION_NAME=ccbot

# Codex command to run in new windows (optional, defaults to "codex")
CCBOT_CODEX_COMMAND=codex

# Codex transcript root (optional, defaults to ~/.codex)
# CCBOT_CODEX_PROJECTS_PATH=~/.codex

# Default directory shown when creating a new Codex session (optional, defaults to ~/Projects)
# CCBOT_DEFAULT_PROJECTS_PATH=~/Projects

# Optional named roots shown before directory browsing.
# Use mounted paths for other computers/VPSes, e.g. SSHFS/NFS mounts.
# CCBOT_PROJECT_ROOTS=Local=~/Projects,Remote=/mnt/remote-projects

# Monitor polling interval in seconds (optional, defaults to 2.0)
MONITOR_POLL_INTERVAL=2.0

# Automatically check and fast-forward git source installs on startup.
# Set to false if you manage upgrades manually.
CCBOT_AUTO_UPDATE=true

# Minimum seconds between automatic startup checks (optional, defaults to 86400)
CCBOT_UPDATE_INTERVAL_SECONDS=86400

# Only apply automatic updates when no Codex pane is working or waiting for input.
CCBOT_UPDATE_REQUIRE_IDLE=true

# When work is active, retry the idle check after this many seconds.
CCBOT_UPDATE_BUSY_RETRY_SECONDS=300

# Check Codex CLI npm package updates during the same idle update loop.
CCBOT_CODEX_UPDATE_CHECK=true

# Keep false unless you want ccbot to run `npm install -g @openai/codex@latest`.
CCBOT_CODEX_AUTO_UPDATE=false

# Show Codex commentary/thinking updates in Telegram (optional)
CCBOT_SHOW_COMMENTARY_MESSAGES=true

# Optional OpenAI-compatible endpoint for voice transcription
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
